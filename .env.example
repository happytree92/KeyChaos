# ─── KeyChaos — Environment Variables ───────────────────────────────────────
# Copy this to .env (or set in docker-compose.yml) before running.
# .env is gitignored — never commit real credentials.

# Server
PORT=3000

# ─── Authentication (MANDATORY) ─────────────────────────────────────────────
# Basic Auth is ON by default. Both vars required.
KC_AUTH_USER=admin
KC_AUTH_PASS=changeme

# Set to true ONLY if you handle auth at the reverse proxy level instead.
# KC_AUTH_DISABLED=true

# ─── PwdPush ─────────────────────────────────────────────────────────────────
# Default: pwpush.com — change for self-hosted instances
PWD_PUSH_URL=https://pwpush.com
# API token from your PwdPush account (server-side only, never exposed to browser)
PWD_PUSH_TOKEN=your_token_here
# 'v2' for pwpush.com and Self-Hosted Pro | 'v1' for open-source self-hosted
PWD_PUSH_API_VERSION=v2
